{
  "name": "picture-map",
  "private": true,
  "main": "main.js",
  "type": "module",
  "version": "1.0.0",
  "license": "ISC",
  "scripts": {
    "start": "nodemon --exec electron .",
    "build": "electron-builder",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd picMap_backend && npm start",
    "dev:frontend": "cd picMap_fontend && npm run dev",
    "install:all": "npm install && cd picMap_backend && npm install && cd ../picMap_fontend && npm install"
  },
  "build": {
    "asar": false,
    "appId": "picture-map",
    "productName": "picture-map",
    "files": [
      "main.js",
      "preload.js",
      "picMap_backend/dist/**",
      "picMap_backend/node_modules/**",
      "picMap_backend/package.json",
      "picMap_fontend/dist/**",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "安装快捷方式的名称"
    },
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "./ico/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
"devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.10"
  }
}